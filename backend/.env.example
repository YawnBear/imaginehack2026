# GreenGuard Cloud — backend environment (EXAMPLE / placeholders only)
# Copy to backend/.env for local dev. The REAL key is set only in the Render
# dashboard at deploy time — never commit a real sk-grafilab-... value.

# --- Hybrid AI layer (OPTIONAL) ---------------------------------------------
# The deterministic rule engine is the source of truth. The AI only rewrites
# the per-agent analysis TEXT. With a placeholder/blank key the app works
# identically to today via deterministic template fallback (AI disabled).
# AI is treated as DISABLED while the value is blank or contains REPLACE/your-key.
AI_PROVIDER_API_KEY=sk-grafilab-REPLACE_ME
AI_PROVIDER_BASE_URL=https://console-api.grafilab.ai/api/
AI_MODEL=grafilab-chat

# --- Core --------------------------------------------------------------------
# Leave DATABASE_URL blank to use the in-memory store.
DATABASE_URL=
# Production frontend origin (CORS). On Vercel set this to your deployed URL.
FRONTEND_ORIGIN=
LOCAL_FRONTEND_ORIGIN=http://localhost:3000
# Seed demo events on startup so the dashboard has data.
SEED_DATA_ENABLED=true
