# GreenGuard Cloud — frontend environment (EXAMPLE / placeholders only)
# Copy to .env.local for local dev.

# Public base URL the browser uses to reach the API. Leave blank to use the
# Next.js rewrite proxy (/api -> API_PROXY_TARGET) defined in next.config.ts.
NEXT_PUBLIC_API_BASE_URL=

# Where the Next.js dev/proxy forwards /api requests. Locally this is the
# FastAPI backend. On Vercel, point this at the deployed Render backend URL
# (e.g. https://greenguard-api.onrender.com).
API_PROXY_TARGET=http://127.0.0.1:8011
