# GreenGuard Cloud — frontend environment (EXAMPLE / placeholders only)
# Copy to .env.local for local dev.

# Public base URL the browser uses to reach the API.
# Local proxy example: http://localhost:3000
# Direct backend example: https://your-render-backend.onrender.com
# Leave blank only when you want the bundled mock-data fallback.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Where the Next.js rewrite proxy forwards /api and /healthz requests.
# Use your local FastAPI URL for local proxy mode. On Vercel, this is only
# needed if NEXT_PUBLIC_API_BASE_URL points at the Vercel frontend URL.
API_PROXY_TARGET=http://127.0.0.1:8011
